<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Interpreter's video fills the screen -->
    <FrameLayout
        android:id="@+id/remoteVideoContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- User's own camera preview, small corner overlay -->
    <FrameLayout
        android:id="@+id/localVideoContainer"
        android:layout_width="120dp"
        android:layout_height="160dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_margin="16dp"
        android:background="#333333" />

    <TextView
        android:id="@+id/tvCallInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="24dp"
        android:textColor="@color/text_light"
        android:textSize="16sp"
        android:textStyle="bold"
        android:background="#66000000"
        android:padding="8dp" />

    <ImageButton
        android:id="@+id/btnEndCall"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="32dp"
        android:background="@color/urgent_red"
        android:contentDescription="@string/end_call"
        android:src="@android:drawable/ic_menu_close_clear_cancel" />

</RelativeLayout>
